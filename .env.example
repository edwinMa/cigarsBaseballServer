# Database
DATABASE_URL=postgres://localhost:5432/cigarsbaseball

# JWT Secret (change this to a long random string in production)
JWT_SECRET=cigars-baseball-secret-change-in-production

# Admin account (used by seed.js)
ADMIN_EMAIL=admin@cigarsbaseball.org
ADMIN_PASSWORD=CigarsAdmin2024!

# Email (SMTP) - example using Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Cigars Baseball" <your-gmail@gmail.com>

# Twilio SMS
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+15555555555

# Frontend URL (for links in notification emails)
FRONTEND_URL=https://cigarsbaseball.org
