{
  "name": "Cigars Baseball",
  "description": "Cigars Baseball API with PostgreSQL database and admin dashboard",
  "addons": [
    "heroku-postgresql:essential-0"
  ],
  "env": {
    "SESSION_SECRET": {
      "description": "Secret key for session encryption",
      "generator": "secret"
    },
    "NODE_ENV": {
      "value": "production"
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ]
}
